{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mxfff114-star/ask-up/contracts/approval-request.schema.json",
  "title": "AskUp Approval Request",
  "type": "object",
  "required": ["schema_version", "request_id", "task_id", "action_type", "target", "parameters", "effect_summary", "status", "expires_at"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "request_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "action_type": { "type": "string", "minLength": 1 },
    "target": { "type": "string", "minLength": 1 },
    "parameters": { "type": "object" },
    "effect_summary": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["pending", "approved", "rejected", "expired"] },
    "expires_at": { "type": "string", "format": "date-time" },
    "approved_at": { "type": "string", "format": "date-time" },
    "approver": { "type": "string" }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "approved" } } },
      "then": { "required": ["approved_at", "approver"] }
    }
  ]
}
